# Existing AI key
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MESSAGE_NUDGES_MODEL=gpt-4.1-mini

# Supabase auth
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe billing foundation (Sprint 8)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# AOC Capital — optional live PUBLIC market data (PAPER TRADING ONLY, PR #7)
# Server-only setting — deliberately NOT prefixed NEXT_PUBLIC_.
# Allowed values: "mock" (default, always simulated), "live_public" (read-only
# public price feed with automatic fallback to simulated prices), or
# "disabled" (live fetch never attempted; simulated prices used and shown as
# such). Unset or any other value is treated as "mock". The provider used
# (coingecko) is a free, keyless public price endpoint — no API key exists or
# is ever read for this feature. This NEVER enables real trading, broker
# connections, order routing, or withdrawals — see
# src/lib/trading/live-price-provider.ts.
AOC_CAPITAL_MARKET_DATA_MODE=mock
MARKET_DATA_PROVIDER=coingecko
