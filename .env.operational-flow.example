# ──────────────────────────────────────────────────────────────────────────────
# Operational-flow runtime gate — environment variables
#
# CRITICAL: Use an isolated, throwaway Supabase project.
#           NEVER point these variables at a production Supabase project.
#           This gate creates and hard-deletes auth users, workspaces,
#           projects, evidence items, signals, decisions and audit records.
#
# Setup instructions: docs/operational-flow-runtime-gate.md
# ──────────────────────────────────────────────────────────────────────────────

# ── App (must match the Supabase project below) ───────────────────────────────

# Your isolated Supabase project URL  (e.g. http://localhost:54321)
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key from the isolated project
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — ONLY for local/test use, never commit, never use in prod
SUPABASE_SERVICE_ROLE_KEY=

# ── Runtime gate (check:operational-flow-db) ──────────────────────────────────

# Same URL as NEXT_PUBLIC_SUPABASE_URL above (duplicated so the gate script
# can run independently of the app env)
OPERATIONAL_FLOW_TEST_SUPABASE_URL=

# Same anon key as NEXT_PUBLIC_SUPABASE_ANON_KEY
OPERATIONAL_FLOW_TEST_ANON_KEY=

# Same service-role key as SUPABASE_SERVICE_ROLE_KEY
OPERATIONAL_FLOW_TEST_SERVICE_ROLE_KEY=

# Base URL where the Next.js app is running locally (must be same Supabase project)
OPERATIONAL_FLOW_TEST_BASE_URL=http://localhost:3000

# Explicit opt-in: this check creates and deletes real data.
# Must be the string "true" — any other value causes exit 2.
OPERATIONAL_FLOW_TEST_ALLOW_DESTRUCTIVE=true

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to "true" only if your isolated project is on a non-localhost remote URL
# (e.g. a disposable Supabase branch project). The gate aborts by default if
# the URL does not resolve to localhost.
# OPERATIONAL_FLOW_TEST_ALLOW_REMOTE=true
